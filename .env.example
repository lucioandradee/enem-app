# =====================================================
# ENEM MASTER — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas chaves.
# NUNCA commite o arquivo .env com valores reais!
# =====================================================

# Supabase — obtenha em: supabase.com → Settings → API
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui

# Supabase Management API (para rodar migrate.js)
# Gere em: supabase.com → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=seu_personal_access_token_aqui
